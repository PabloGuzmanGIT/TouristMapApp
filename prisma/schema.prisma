// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlaceCategory {
  // Gastronomía y comercio
  restaurant
  cafe
  bar
  market

  // Turismo / cultura
  turistico
  historico
  museo
  iglesia
  plaza_parque
  centro_cultural

  // Naturaleza
  naturaleza
  mirador
  sendero
  cascada_laguna

  // Tiendas y artesanías
  tienda
  artesania

  // Servicios públicos/útiles
  servicio
  salud
  banco
  policia
  municipalidad
  transporte

  // Información / trabajo / energía
  infoturismo
  cowork
  gasolinera

  // Alojamiento & otros
  alojamiento
  instagrameable
  random
}

enum PublishStatus {
  draft
  pending
  published
  rejected
}

enum EventCategory {
  festival
  cultural
  religioso
  gastronomico
  deportivo
}

enum VideoCategory {
  documental
  clip
  drone
  entrevista
}

enum ResearchType {
  tesis
  articulo
  investigacion
  libro
}

model City {
  id   String @id @default(cuid())
  slug String @unique
  name String

  // cámara del mapa
  centerLat Float
  centerLng Float
  bboxW     Float?
  bboxS     Float?
  bboxE     Float?
  bboxN     Float?

  // Metadata para hero y presentación
  heroImage   String?   // URL de la imagen de fondo del hero
  subtitle    String?   // e.g. "Ciudad de las 33 Iglesias"
  description String?   // Descripción larga para el hero
  altitude    Int?      // metros sobre el nivel del mar
  stats       Json?     // { "iglesias": 33, "puntos": 47, "tours": 12 }

  areas      Area[]
  places     Place[]
  events     Event[]
  tours      Tour[]
  videos     Video[]
  researches Research[]
  editors    User[] @relation("CityEditors")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  slug   String
  name   String
  status PublishStatus @default(published)

  // cámara del mapa
  centerLat Float
  centerLng Float
  bboxW     Float?
  bboxS     Float?
  bboxE     Float?
  bboxN     Float?

  places Place[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // slug único dentro de la ciudad
  @@unique([cityId, slug])
  @@index([cityId, status])
}

model Place {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id], onDelete: SetNull)

  slug     String
  name     String
  category PlaceCategory
  status   PublishStatus @default(published)
  featured Boolean       @default(false)

  // geolocalización
  lat Float
  lng Float

  // contenido de ficha
  short      String?
  details    Json? // JSONB libre (amenities, accessibility, tags, etc.)
  images     Json? // string[] (URLs de Cloudinary)
  rating     Float? // rating propio (si defines uno manual)
  bookingUrl String?
  website    String?
  phone      String?
  address    String?
  schedule   Json? // { mon:[{open,close}], ... } + excepciones si quieres

  // agregados de reseñas (publicadas)
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  reviews PlaceReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // slug único por ciudad
  @@unique([cityId, slug])
  @@index([areaId])
  @@index([status])
  @@index([category])
}

// ======= NUEVOS MODELOS — City Page Redesign =======

model Event {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?
  category    EventCategory

  startDate DateTime
  endDate   DateTime?
  duration  String?    // "10 días", "1 semana"
  location  String?    // "Centro Histórico"
  image     String?    // URL de imagen de portada

  status    PublishStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([cityId, slug])
  @@index([cityId, startDate])
  @@index([cityId, status])
}

model Tour {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?
  duration    String        // "4 horas", "Día completo"
  price       Float         // en PEN (soles)
  currency    String        @default("PEN")
  highlights  Json?         // string[] — ["⛪ 8 iglesias", "📸 Foto stops"]
  image       String?       // URL imagen de portada
  images      Json?         // string[] URLs adicionales

  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)

  whatsappNumber String?    // Para reservas por WhatsApp
  bookingUrl     String?

  status    PublishStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([cityId, slug])
  @@index([cityId, status])
}

model Video {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  title        String
  slug         String
  description  String?
  category     VideoCategory

  thumbnailUrl String?    // URL miniatura
  videoUrl     String?    // YouTube/Vimeo embed URL
  duration     String?    // "28 min"
  views        Int        @default(0)
  featured     Boolean    @default(false)

  publishedAt DateTime?
  status      PublishStatus @default(published)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([cityId, slug])
  @@index([cityId, status])
}

model Research {
  id     String @id @default(cuid())
  cityId String
  city   City   @relation(fields: [cityId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?
  type        ResearchType
  category    String?       // "Historia", "Arqueología", etc.

  authorName  String
  institution String?       // "UNSCH", "PUCP"

  year  Int?
  pages Int?
  doi   String?
  url   String?

  status    PublishStatus @default(published)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([cityId, slug])
  @@index([cityId, status])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String? // Hashed password
  image         String?
  role          String    @default("user") // user, admin, editor
  
  // For editors: can only manage places/reviews in their assigned city
  managedCityId String?
  managedCity   City?    @relation("CityEditors", fields: [managedCityId], references: [id], onDelete: SetNull)
  
  // Password recovery
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  
  // NextAuth.js relations
  accounts Account[]
  sessions Session[]
  
  // App relations
  reviews       PlaceReview[]
  comments      ReviewComment[]
  reviewHelpful ReviewHelpful[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// NextAuth.js Account model
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js Session model
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js Verification Token model
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlaceReview {
  id      String @id @default(cuid())
  placeId String
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  rating  Int // 1..5
  title   String?
  content String?
  images  Json? // string[] opcional
  status  PublishStatus @default(pending)

  helpful  ReviewHelpful[]
  comments ReviewComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Nota: con userId nullable, este unique no limita anónimos (varios NULL son válidos en Postgres).
  // Úsalo si tendrás auth; si no, controla por IP/cookie en la lógica.
  @@unique([placeId, userId])
  @@index([placeId, status, createdAt])
}

model ReviewHelpful {
  id       String      @id @default(cuid())
  reviewId String
  review   PlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
}

model ReviewComment {
  id       String      @id @default(cuid())
  reviewId String
  review   PlaceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  content String
  status  PublishStatus @default(published)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reviewId, status, createdAt])
}
